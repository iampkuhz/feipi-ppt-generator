{
  "agent": "main-default",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [],
    "allow": [],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.mcp.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(chmod -R 777 /:*)",
      "Bash(dd if=* of=/dev/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "matcher": ".*", "hooks": [{ "type": "command", "command": ".claude/hooks/session-start.sh" }] }
    ],
    "SubagentStart": [
      { "matcher": ".*", "hooks": [{ "type": "command", "command": ".claude/hooks/subagent-start.sh" }] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": ".claude/hooks/pre-bash.sh" }] },
      { "matcher": "Write", "hooks": [{ "type": "command", "command": ".claude/hooks/pre-write.sh" }] },
      { "matcher": "Edit", "hooks": [{ "type": "command", "command": ".claude/hooks/pre-write.sh" }] },
      { "matcher": "MultiEdit", "hooks": [{ "type": "command", "command": ".claude/hooks/pre-write.sh" }] }
    ],
    "PostToolUse": [
      { "matcher": "Write", "hooks": [{ "type": "command", "command": ".claude/hooks/post-write.sh" }] },
      { "matcher": "Edit", "hooks": [{ "type": "command", "command": ".claude/hooks/post-write.sh" }] },
      { "matcher": "MultiEdit", "hooks": [{ "type": "command", "command": ".claude/hooks/post-write.sh" }] }
    ],
    "PostToolUseFailure": [
      { "matcher": ".*", "hooks": [{ "type": "command", "command": ".claude/hooks/tool-failure.sh" }] }
    ],
    "Stop": [
      { "matcher": ".*", "hooks": [{ "type": "command", "command": ".claude/hooks/stop.sh" }] }
    ],
    "SubagentStop": [
      { "matcher": ".*", "hooks": [{ "type": "command", "command": ".claude/hooks/subagent-stop.sh" }] }
    ],
    "ConfigChange": [
      { "matcher": ".*", "hooks": [{ "type": "command", "command": ".claude/hooks/config-change.sh" }] }
    ]
  }
}
