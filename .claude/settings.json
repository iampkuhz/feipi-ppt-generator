{
  "agent": "main-default",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [],
    "allow": [],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.mcp.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(chmod -R 777 /:*)",
      "Bash(dd if=* of=/dev/*)"
    ]
  },
  "hooks": {
    "SessionStart": ".claude/hooks/session-start.sh",
    "SubagentStart": ".claude/hooks/subagent-start.sh",
    "PreToolUse": {
      "Bash": ".claude/hooks/pre-bash.sh",
      "Write": ".claude/hooks/pre-write.sh",
      "Edit": ".claude/hooks/pre-write.sh",
      "MultiEdit": ".claude/hooks/pre-write.sh"
    },
    "PostToolUse": {
      "Write": ".claude/hooks/post-write.sh",
      "Edit": ".claude/hooks/post-write.sh",
      "MultiEdit": ".claude/hooks/post-write.sh"
    },
    "PostToolUseFailure": ".claude/hooks/tool-failure.sh",
    "Stop": ".claude/hooks/stop.sh",
    "SubagentStop": ".claude/hooks/subagent-stop.sh",
    "ConfigChange": ".claude/hooks/config-change.sh"
  }
}
